{
    "name": "convex-agents",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*"
        ],
        "catalog": {
            "dotenv": "^17.2.2",
            "zod": "^4.1.13",
            "lucide-react": "^0.546.0",
            "next-themes": "^0.4.6",
            "react": "^19.2.3",
            "react-dom": "^19.2.3",
            "sonner": "^2.0.5",
            "tailwindcss": "^4.1.18",
            "convex": "^1.32.0",
            "better-auth": "1.4.9",
            "@convex-dev/better-auth": "^0.10.13",
            "@types/react": "^19.2.10",
            "@types/react-dom": "^19.2.3",
            "alchemy": "^0.82.1"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "check-types": "turbo check-types",
        "dev:web": "turbo -F @convex-agents/infra dev",
        "dev:server": "turbo -F @convex-agents/backend dev",
        "dev:setup": "turbo -F @convex-agents/backend dev:setup",
        "deploy": "turbo -F @convex-agents/infra deploy",
        "destroy": "turbo -F @convex-agents/infra destroy",
        "check": "biome check --write .",
        "prepare": "husky"
    },
    "dependencies": {
        "@convex-agents/env": "workspace:*",
        "dotenv": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@cloudflare/workers-types": "^4.20251213.0",
        "@convex-agents/config": "workspace:*",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "turbo": "^2.8.12",
        "typescript": "^5"
    },
    "lint-staged": {
        "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
            "biome check --write ."
        ]
    },
    "packageManager": "bun@1.3.3"
}
